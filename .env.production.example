# Public domain
NEXT_PUBLIC_SITE_URL="https://h2h.techsasaonline.com"

# Managed PostgreSQL. Require SSL when your provider supports it.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Initial administrator. Replace every placeholder before deployment.
ADMIN_EMAIL="admin@your-domain.com"
ADMIN_PASSWORD="replace-with-a-strong-temporary-password"
ADMIN_SESSION_SECRET="replace-with-at-least-32-random-characters"

# Safaricom Daraja. Keep sandbox until the complete payment flow is verified.
MPESA_ENVIRONMENT="sandbox"
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE=""
MPESA_PASSKEY=""
MPESA_CALLBACK_URL="https://h2h.techsasaonline.com/api/payments/mpesa/callback"

# Notification providers
EMAIL_PROVIDER_API_KEY=""
SMS_PROVIDER_API_KEY=""
